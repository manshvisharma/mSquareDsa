rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    // Check if user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if the user is the owner of the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Check if the user has the 'admin' role in their database profile
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Collection Rules ---

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) 
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow update: if isAdmin();
    }

    // 2. Global Content (Sheets, Topics, SubPatterns, Problems, SQL features)
    match /sheets/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /topics/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /subpatterns/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /problems/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    
    // ✅ SQL Problems access
    match /sqlProblems/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ✅ SQL Topic Batches access
    match /sqlTopicBatches/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ✅ Learning Courses access
    match /learnCourses/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ✅ Learning Topics access
    match /learnTopics/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ✅ Learning Lessons access
    match /learnLessons/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ✅ Learning Slides access
    match /learnSlides/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 3. User Data (Notes & Submissions)
    match /notes/{noteId} {
      allow read, write: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
    
    // ✅ SQL Submissions access
    match /sqlSubmissions/{docId} {
      allow read, write: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
    
    // ✅ SQL Drafts access
    match /sqlDrafts/{docId} {
      allow read, write: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
    
    // 4. Messages (Inbox & Chat)
    match /messages/{messageId} {
      allow read: if isAuthenticated() && 
                  (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isAuthenticated() && 
                    request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
                            (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
    }
    
  }
}